   <string notr="true">/* 整体背景变暗 */
QWidget {
    background-color: #1E1E24;
    color: #E0E0E0;
}

/* 视频显示区设为纯黑，加点边框 */
#label_video {
    background-color: #000000;
    border: 2px solid #00A8E8; /* 科技蓝边框 */
    border-radius: 4px;
}

/* 左侧数据区稍微亮一点点作区分 */
#widget_3 {
    background-color: #2B2B36;
    border-right: 1px solid #3A3A4A;
}

/* 底部按钮的工业风设计 */
QPushButton {
    background-color: #333344;
    border: 1px solid #00A8E8;
    color: #00A8E8;
    font-size: 16px;
    font-weight: bold;
    padding: 15px;
    border-radius: 5px;
}

/* 按钮按下的效果 */
QPushButton:pressed {
    background-color: #00A8E8;
    color: #1E1E24;
}</string>
